{
  "name": "deliberate",
  "version": "1.0.5",
  "description": "Review-first explainability companion for agentic coding workflows",
  "type": "module",
  "bin": {
    "deliberate": "./bin/cli.js"
  },
  "main": "./src/index.js",
  "files": [
    ".claude-plugin/",
    "bin/",
    "src/",
    "hooks/",
    "opencode/",
    "antigravity/",
    "gemini/",
    "README.md"
  ],
  "scripts": {
    "start": "node src/server.js",
    "install-hooks": "node src/install.js",
    "preuninstall": "node src/uninstall.js",
    "test": "node --test --test-concurrency=1",
    "gui:install": "npm --prefix gui install",
    "gui:dev": "npm --prefix gui run tauri dev",
    "gui:build": "npm --prefix gui run tauri build",
    "gui:check": "npm --prefix gui run check"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "commander": "^12.0.0",
    "express": "^4.18.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "security",
    "ai-safety",
    "command-analysis"
  ],
  "author": "Deliberate",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-radar/deliberate"
  }
}
